@using WhlgPublicWebsite.BusinessLogic.Models
@model WhlgPublicWebsite.Controllers.LaWordingPreviewViewModel

@{
    Layout = null;
    var allLas = (IEnumerable<(string, string)>)ViewBag.AllLas;
    var statuses = (IEnumerable<LocalAuthorityData.LocalAuthorityStatus>)ViewBag.Statuses;
    var selectedCode = (string)ViewBag.SelectedCode;
    var selectedStatus = (LocalAuthorityData.LocalAuthorityStatus?)ViewBag.SelectedStatus;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <title>LA Wording Preview [DEV]</title>
    <style>
        body { font-family: sans-serif; margin: 2rem; }
        h1 { font-size: 1.5rem; }
        form { margin-bottom: 2rem; display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; }
        label { display: block; font-weight: bold; margin-bottom: 0.25rem; }
        select { padding: 0.4rem; font-size: 1rem; }
        button { padding: 0.4rem 1rem; font-size: 1rem; cursor: pointer; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 2rem; }
        th, td { border: 1px solid #ccc; padding: 0.5rem 0.75rem; vertical-align: top; }
        th { background: #f3f3f3; text-align: left; white-space: nowrap; }
        .partial-path { font-family: monospace; font-size: 0.85rem; color: #555; margin-bottom: 0.5rem; }
        .partial-content { border-top: 1px dashed #ccc; padding-top: 0.5rem; margin-top: 0.5rem; }
        .default-badge { color: #888; font-style: italic; }
    </style>
</head>
<body>

<h1>LA Wording Preview <span style="color:red">[DEV ONLY]</span></h1>

<form method="get">
    <div>
        <label for="custodianCode">Local Authority</label>
        <select id="custodianCode" name="custodianCode">
            <option value="">-- select --</option>
            @foreach (var la in allLas)
            {
                if (la.Item1 == selectedCode)
                {
                    <option value="@la.Item1" selected="selected">@la.Item2 (@la.Item1)</option>
                }
                else
                {
                    <option value="@la.Item1">@la.Item2 (@la.Item1)</option>
                }
            }
        </select>
    </div>
    <div>
        <label for="status">Status override</label>
        <select id="status" name="status">
            <option value="">-- select --</option>
            @foreach (var s in statuses)
            {
                if (s == selectedStatus)
                {
                    <option value="@s" selected="selected">@s</option>
                }
                else
                {
                    <option value="@s">@s</option>
                }
            }
        </select>
    </div>
    <button type="submit">Preview</button>
</form>

@if (Model != null)
{
    <h2>@Model.LaName — @Model.SelectedStatus</h2>

    var pages = new (string Name, string Path, object PartialModel)[]
    {
        ("Eligible",             Model.EligiblePartialPath,             Model.EligiblePartialModel),
        ("Confirmation",         Model.ConfirmationPartialPath,         Model.ConfirmationPartialModel),
        ("NotParticipating",     Model.NotParticipatingPartialPath,     Model.NotParticipatingPartialModel),
        ("ReferralsPaused",      Model.ReferralsPausedPartialPath,      Model.ReferralsPausedPartialModel),
        ("NoLongerParticipating",Model.NoLongerParticipatingPartialPath,Model.NoLongerParticipatingPartialModel),
    };

    <table>
        <thead>
            <tr>
                <th>Page</th>
                <th>Partial</th>
                <th>Rendered content</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in pages)
            {
                var isDefault = entry.Path.Contains("/Default.cshtml");
                <tr>
                    <td><strong>@entry.Name</strong></td>
                    <td>
                        <div class="partial-path">@entry.Path</div>
                        @if (isDefault) { <span class="default-badge">default</span> }
                        <div><a href="/dev/la-wording-preview/page?custodianCode=@selectedCode&status=@selectedStatus&page=@entry.Name" target="_blank">View full page ↗</a></div>
                    </td>
                    <td>
                        <div class="partial-content">
                            @await Html.PartialAsync(entry.Path, entry.PartialModel)
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h3 style="font-size:1.1rem;margin-top:1.5rem;">Other LA-dependent pages (no custom partial)</h3>
    <table>
        <thead>
            <tr><th>Page</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var name in new[] { "NoFunding", "Pending", "TakingFutureReferrals", "Ineligible", "NoConsent", "ConfirmLocalAuthority" })
            {
                <tr>
                    <td><strong>@name</strong></td>
                    <td><a href="/dev/la-wording-preview/page?custodianCode=@selectedCode&status=@selectedStatus&page=@name" target="_blank">View full page ↗</a></td>
                </tr>
            }
        </tbody>
    </table>
}

</body>
</html>
