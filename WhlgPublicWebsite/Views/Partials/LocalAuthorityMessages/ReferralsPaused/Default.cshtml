@model WhlgPublicWebsite.Models.Questionnaire.ReferralsPausedViewModel

<h1 class="govuk-heading-l">Your Local Authority is no longer receiving applications via this service</h1>
<h2 class="govuk-heading-m">What to do next</h2>
<p class="govuk-body">
    Your Local Authority, <strong>@Model.LocalAuthorityName</strong>, is no longer receiving applications for the Warm Homes: Local Grant
    as they are oversubscribed. <strong>Please check back in regularly to see if @Model.LocalAuthorityName has more funding available or applications are reopened.</strong>
</p>
<p class="govuk-body">
    If your Local Authority does not seem right, <a class="govuk-link" href="https://www.gov.uk/find-local-council">find your correct Local Authority</a> and contact them directly.
</p>